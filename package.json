{
  "name": "voxeldeck",
  "version": "1.3.0",
  "description": "VoxelDeck — a slick dark-themed dashboard for managing your game servers (Minecraft, Terraria, Valheim): one-click install, files, mods/plugins, players, a live console, and auto/scheduled restarts.",
  "main": "src/main/main.js",
  "author": "VoxelDeck",
  "homepage": "https://therealsamkothatsreal.github.io/voxeldeck/",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheRealSamkoThatsReal/voxeldeck.git"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node test/core.test.mjs && node test/lifecycle.test.cjs && node test/scheduler.test.cjs && node test/games-lifecycle.test.cjs && node test/client-mods.test.cjs",
    "test:tour": "electron test/tour-flow.cjs",
    "test:clientmods": "electron test/clientmods-smoke.cjs",
    "install-desktop": "bash scripts/install-desktop.sh",
    "dist": "electron-builder --linux AppImage deb",
    "dist:win": "electron-builder --win nsis portable"
  },
  "build": {
    "appId": "com.voxeldeck.app",
    "productName": "VoxelDeck",
    "executableName": "voxeldeck",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "TheRealSamkoThatsReal",
        "repo": "voxeldeck",
        "releaseType": "release"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game",
      "icon": "src/renderer/assets/icon.png",
      "maintainer": "VoxelDeck <dev@localhost>",
      "synopsis": "Manage your Minecraft servers from one dashboard"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/renderer/assets/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.games"
    },
    "appImage": {
      "artifactName": "VoxelDeck.AppImage"
    },
    "deb": {
      "artifactName": "voxeldeck.deb"
    },
    "nsis": {
      "artifactName": "VoxelDeck-Setup.exe"
    },
    "portable": {
      "artifactName": "VoxelDeck-Portable.exe"
    },
    "dmg": {
      "artifactName": "VoxelDeck.dmg"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3"
  }
}
